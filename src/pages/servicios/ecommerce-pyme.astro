---
import Layout from '../../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout 
  title="Tienda Online PYME | Digital Solutions - Vende por WhatsApp"
  description="Optimiza tus ventas locales con una tienda online sincronizada con Google Sheets. Recibe pedidos directamente en WhatsApp con una interfaz rápida y profesional."
>
  
  <!-- 1. HERO SECTION -->
  <section class="relative bg-[#1d4ed8] text-white pt-32 pb-16 lg:pt-48 lg:pb-32 overflow-hidden flex items-center">
    <div class="absolute top-0 right-0 w-2/3 h-full bg-[#2563eb] rounded-bl-full opacity-50 pointer-events-none transform translate-x-1/4"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 w-full fade-in-up text-center lg:text-left">
      <div class="flex flex-col lg:flex-row items-center gap-16">
        <div class="w-full lg:w-3/5 space-y-8">
          <div class="inline-block bg-[#3b82f6] text-white px-4 py-1.5 rounded-full text-xs font-black uppercase tracking-widest shadow-sm">
            Social Commerce Ready
          </div>
          <h1 class="text-4xl sm:text-6xl lg:text-[7.5rem] font-black tracking-tighter leading-[0.9] lg:leading-[0.8] mb-6">
            Tienda Online<br />
            <span class="text-[#60a5fa]">PYME<span class="text-white">.</span></span>
          </h1>
          <p class="text-lg lg:text-xl text-blue-100 max-w-xl leading-relaxed font-medium">
            Venta digital sin fricciones. Sincroniza tu inventario desde la nube y recibe pedidos directamente en WhatsApp con ingeniería de carga ultra rápida.
          </p>
          <div class="flex flex-wrap gap-4 pt-4 justify-center lg:justify-start">
             <a href="https://wa.me/584124683230" class="bg-[#25D366] text-white px-8 py-4 rounded-full font-bold uppercase tracking-widest text-sm hover:bg-[#22c55e] shadow-lg shadow-green-500/25 transition-all flex items-center gap-2">Vender por WhatsApp</a>
             <a href={`${base}precios`} class="bg-[#1e293b]/10 border border-[#1e293b]/20 text-[#1e293b] px-8 py-4 rounded-full font-bold uppercase tracking-widest text-sm hover:bg-[#1e293b]/20 transition-all">Ver Otros Planes</a>
          </div>
        </div>
        <div class="w-full lg:w-2/5 relative hidden lg:block">
           <div class="aspect-square bg-gradient-to-br from-[#25D366] to-[#15803d] rounded-[3.5rem] rotate-3 relative overflow-hidden shadow-2xl border border-white/10 flex items-center justify-center group">
              <div class="absolute inset-0 bg-blue-600/10 group-hover:scale-110 transition-transform duration-700"></div>
              <svg class="w-48 h-48 text-white relative z-10 opacity-20" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- 2. ARCHITECTURE & PRICING -->
  <section class="py-32 bg-white">
    <div class="max-w-7xl mx-auto px-6">
      <div class="flex flex-col lg:flex-row gap-20 items-center">
        
        <!-- Left: Technical Efficiency -->
        <div class="w-full lg:w-1/2">
           <span class="text-[#2563eb] font-bold text-sm tracking-[0.3em] uppercase block mb-4">Eficiencia Operativa</span>
           <h2 class="text-4xl lg:text-5xl font-black text-[#0f172a] tracking-tighter leading-none mb-10">Gestión Dinámica<br/> <span class="text-[#25D366]">En Tiempo Real.</span></h2>
           
           <div class="space-y-8">
              <div class="eng-hover flex gap-6 items-start p-8 rounded-[2rem] bg-slate-50/50 border border-transparent hover:bg-white transition-all shadow-sm hover:shadow-xl">
                 <div class="w-12 h-12 rounded-2xl bg-white flex items-center justify-center text-[#2563eb] border border-slate-100 shadow-sm transition-all shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                 </div>
                 <div>
                    <h4 class="font-bold text-[#0f172a] text-xl mb-2">Catálogo Google Sheets</h4>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">Controla precios, stock y fotos desde una simple hoja de cálculo. Tu tienda se actualiza automáticamente.</p>
                 </div>
              </div>
              <div class="eng-hover flex gap-6 items-start p-8 rounded-[2rem] bg-slate-50/50 border border-transparent hover:bg-white transition-all shadow-sm hover:shadow-xl">
                 <div class="w-12 h-12 rounded-2xl bg-white flex items-center justify-center text-[#25D366] border border-slate-100 shadow-sm transition-all shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
                 </div>
                 <div>
                    <h4 class="font-bold text-[#0f172a] text-xl mb-2">Carrito Premium</h4>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">Experiencia de compra fluida con persistencia de productos y buscador inteligente de alta velocidad.</p>
                 </div>
              </div>
              <div class="eng-hover flex gap-6 items-start p-8 rounded-[2rem] bg-slate-50/50 border border-transparent hover:bg-white transition-all shadow-sm hover:shadow-xl">
                 <div class="w-12 h-12 rounded-2xl bg-white flex items-center justify-center text-[#2563eb] border border-slate-100 shadow-sm transition-all shrink-0">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                 </div>
                 <div>
                    <h4 class="font-bold text-[#0f172a] text-xl mb-2">Despliegue en 2 Semanas</h4>
                    <p class="text-sm text-slate-500 font-medium leading-relaxed">Metodología ágil para llevar tu negocio al ecosistema digital en tiempo récord sin sacrificar calidad técnica.</p>
                 </div>
              </div>
           </div>
        </div>

        <!-- Right: Pricing Card -->
        <div class="w-full lg:w-1/2 flex justify-center">
           <div class="eng-hover glow-on-hover relative bg-white rounded-[4rem] p-12 lg:p-16 border border-slate-100 shadow-[0_20px_60px_rgba(37,99,235,0.05)] overflow-hidden group hover:border-[#25D366] transition-all duration-700 w-full max-w-xl">
              <div class="flex flex-col items-center mb-10">
                 <span class="text-slate-300 text-sm font-black line-through mb-1 uppercase tracking-widest opacity-70">$300 USD</span>
                 <div class="flex items-baseline gap-3">
                    <span class="text-8xl font-black text-[#2563eb] tracking-tighter">$180</span>
                    <span class="text-slate-400 text-lg font-black uppercase tracking-widest">Total</span>
                 </div>
              </div>
              
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-6 text-left mb-12 max-w-lg mx-auto border-y border-slate-100 py-8">
                 <li class="flex items-center gap-4 text-slate-600 font-bold text-xs list-none"><svg class="w-4 h-4 text-[#25D366]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"></path></svg>Catálogo Cloud</li>
                 <li class="flex items-center gap-4 text-slate-600 font-bold text-xs list-none"><svg class="w-4 h-4 text-[#25D366]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"></path></svg>Carrito de Compra Pro</li>
                 <li class="flex items-center gap-4 text-slate-600 font-bold text-xs list-none"><svg class="w-4 h-4 text-[#25D366]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"></path></svg>Pedidos WhatsApp</li>
                 <li class="flex items-center gap-4 text-slate-600 font-bold text-xs list-none"><svg class="w-4 h-4 text-[#25D366]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"></path></svg>Soporte por 1 año</li>
                 <li class="flex items-center gap-4 text-slate-600 font-bold text-xs list-none"><svg class="w-4 h-4 text-[#25D366]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"></path></svg>Hosting Incluido</li>
                 <li class="flex items-center gap-4 text-slate-600 font-bold text-xs list-none"><svg class="w-4 h-4 text-[#25D366]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"></path></svg>Buscador Inteligente</li>
              </div>

              <a href="https://wa.me/584124683230" target="_blank" class="w-full py-6 bg-[#25D366] hover:bg-[#22c55e] text-white font-black uppercase tracking-[0.2em] rounded-[1.5rem] shadow-xl shadow-green-500/20 transition-all hover:scale-[1.02] flex items-center justify-center gap-3 relative z-10">
                 Lanzar Mi Tienda
                 <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path></svg>
              </a>
           </div>
        </div>
      </div>
    </div>
  </section>

</Layout>
