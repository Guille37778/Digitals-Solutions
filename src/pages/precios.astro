---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout 
  title="Planes y Precios | Digital Solutions - Inversión en Ingeniería Web"
  description="Consulta nuestros planes de desarrollo web y branding. Sin mensualidades ocultas, pago único y propiedad total del código. Desde Landings hasta E-commerce Headless."
>
  
  <!-- 1. HERO PRECIOS (High Impact) -->
  <section class="relative bg-[#0f172a] text-white pt-32 pb-32 lg:pt-48 lg:pb-40 overflow-hidden flex items-center">
    <!-- Abstract wavy elements -->
    <div class="absolute top-0 right-0 w-2/3 h-full bg-[#1e3a8a] rounded-bl-full opacity-50 pointer-events-none transform translate-x-1/4"></div>
    <div class="absolute inset-0 bg-[linear-gradient(to_right,rgba(255,255,255,0.03)_1px,transparent_1px),linear-gradient(to_bottom,rgba(255,255,255,0.03)_1px,transparent_1px)] bg-[size:32px_32px] pointer-events-none opacity-40"></div>

    <div class="max-w-7xl mx-auto px-6 relative z-10 w-full fade-in-up">
      <div class="flex flex-col lg:flex-row items-center gap-16">

        <!-- Text (Left) -->
        <div class="w-full lg:w-3/5 text-center lg:text-left space-y-8">
          <div class="inline-block bg-white/10 backdrop-blur-md border border-white/20 text-white px-5 py-2 rounded-full text-[10px] font-black uppercase tracking-[0.2em] shadow-sm">
            Tu Inversión, Tu Propiedad
