        <!-- Abstract Visual Box (Right) -->
        <div class="w-full lg:w-2/5 relative hidden lg:block">
          <div class="aspect-square bg-gradient-to-br from-[#2563eb] to-[#1e40af] rounded-[3.5rem] -rotate-3 relative overflow-hidden shadow-2xl border border-white/10 group flex items-center justify-center">
            <div class="absolute inset-0 bg-blue-600/10 group-hover:scale-110 transition-transform duration-700"></div>
            <div class="absolute inset-0 flex items-center justify-center opacity-20 group-hover:rotate-12 group-hover:scale-110 transition-all duration-700">
              <svg class="w-48 h-48 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
