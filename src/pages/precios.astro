          <h1 class="text-4xl sm:text-6xl lg:text-[7.5rem] font-black tracking-tighter leading-[0.9] lg:leading-[0.8]">
            Planes de <br />
            <span class="text-[#93c5fd]">Ingeniería Web<span class="text-white">.</span></span>
          </h1>

          <p class="text-xl text-[#bfdbfe] max-w-2xl leading-relaxed font-medium opacity-90 mx-auto lg:mx-0">
            Diseño y arquitectura web de alto rendimiento. Pago único y la página web es tuya, libre de mensualidades ocultas.
          </p>

          <!-- Stats row -->
          <div class="flex flex-wrap gap-8 pt-4 justify-center lg:justify-start">
            <div class="text-center lg:text-left">
              <div class="text-3xl font-black text-white">5</div>
              <div class="text-[10px] text-[#93c5fd] font-black uppercase tracking-widest">Planes</div>
            </div>
            <div class="w-px bg-white/20 hidden lg:block"></div>
            <div class="text-center lg:text-left">
              <div class="text-3xl font-black text-white">100%</div>
              <div class="text-[10px] text-[#93c5fd] font-black uppercase tracking-widest">Tuyo</div>
            </div>
            <div class="w-px bg-white/20 hidden lg:block"></div>
            <div class="text-center lg:text-left">
              <div class="text-3xl font-black text-white">$0</div>
              <div class="text-[10px] text-[#93c5fd] font-black uppercase tracking-widest">Mensualidad</div>
            </div>
          </div>
