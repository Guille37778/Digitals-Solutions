  <!-- ANIMACIÓN DE NÚMEROS (CONTADORES) -->
  <script>
    const initCounters = () => {
      const counters = document.querySelectorAll('.counter');
      const section = document.getElementById('stats-section');
      
      if(!section || counters.length === 0) return;
      
      // Asegurarse de que partan en 0 siempre que la página carga
      counters.forEach(c => c.innerText = "0");

      const observer = new IntersectionObserver((entries) => {
        if (entries[0].isIntersecting) {
          counters.forEach(counter => {
            const updateCount = () => {
              const target = +counter.getAttribute('data-target');
              const isFloat = counter.hasAttribute('data-float');
              const count = parseFloat(counter.innerText || "0");
              
              const inc = target / 40; // velocidad (40 iteraciones aproximadas)

              if (count < target) {
                 counter.innerText = isFloat ? (count + inc).toFixed(1) : Math.ceil(count + inc).toString();
                 setTimeout(updateCount, 30); // 30ms delay entre cada número
              } else {
                 counter.innerText = isFloat ? target.toFixed(1) : target.toString();
              }
            };
            updateCount();
          });
          // Dejar de observar una vez la animación suceda
          observer.disconnect();
        }
      }, { threshold: 0.5 }); // Empezar cuando el usuario está a la mitad de la sección

      observer.observe(section);
    };

    // Ejecutar inmediatamente
    initCounters();
    
    // Soporte para Astro View Transitions si están activas
    document.addEventListener('astro:after-swap', initCounters);
  </script>

