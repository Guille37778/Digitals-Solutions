---
const base = import.meta.env.BASE_URL;
---

<footer
  class="bg-[#1e40af] text-white pt-20 pb-8 mt-auto border-t border-[rgba(255,255,255,0.1)]"
>
  <div class="max-w-7xl mx-auto px-6">
    <!-- Top Contact Strip -->
    <div
      class="flex flex-col md:flex-row justify-between items-start md:items-center py-8 border-b border-[#3b82f6]/30 mb-12 gap-6"
    >
      <a
        href={base}
        class="flex items-center gap-3 h-min leading-none tracking-widest uppercase group shrink-0 relative"
      >
        <img
          src={`${base}logo-ds.png`}
          alt="Digital Solutions Logo"
          style="width:100px;height:75px;object-fit:contain;"
          class="shrink-0"
        />
        <div class="flex flex-col leading-none">
          <span class="font-black text-xl italic">Digital</span>
          <span
            class="font-bold text-[8px] opacity-60 border-t border-white/20 pt-0.5"
            >Solutions</span
          >
        </div>
      </a>

      <div class="flex flex-wrap gap-8 lg:gap-16">
        <div class="flex items-center gap-4">
          <div
            class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-white hover:text-[#1e40af] transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path></svg>
          </div>
          <div>
            <p class="text-xs text-[#93c5fd]">Llámanos ahora</p>
            <p class="font-bold">
              <a
                href="tel:+584124683230"
                class="hover:text-white transition-colors">+58 412 468 3230</a>
            </p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div
            class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-white hover:text-[#1e40af] transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path></svg>
          </div>
          <div>
            <p class="text-xs text-[#93c5fd]">Para consultas</p>
            <p class="font-bold">digitalsolutionseficiencia@gmail.com</p>
          </div>
        </div>
        <div class="flex items-center gap-4">
          <div
            class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center hover:bg-white hover:text-[#1e40af] transition-colors"
          >
            <svg
              class="w-4 h-4"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              ><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path><path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
          </div>
          <div>
            <p class="text-xs text-[#93c5fd]">Ubicación</p>
            <p class="font-bold">Valencia, Venezuela</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Main Footer Content -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12 mb-12">
      <!-- About -->
      <div class="space-y-6">
        <h4 class="font-bold text-lg">Sobre Nosotros</h4>
        <p class="text-sm text-[#93c5fd] leading-relaxed pr-6">
          Somos una agencia digital enfocada en conectar el talento humano con
          las mejores tecnologías para impulsar el crecimiento empresarial con
          diseños de impacto.
        </p>
        <div class="flex gap-4">
          <a
            href="https://wa.me/584124683230"
            target="_blank"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#25D366] transition-all group"
          >
            <span class="sr-only">WhatsApp</span>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"
              ><path
                d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
              ></path></svg
            >
          </a>
          <a
            href="#"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-black transition-all group"
          >
            <span class="sr-only">TikTok</span>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"
              ><path
                d="M12.53.02C13.84 0 15.14.01 16.44 0c.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.59-1.01V15.5c0 1.28-.18 2.58-.72 3.73-.54 1.14-1.39 2.14-2.45 2.83-1.05.69-2.31 1.07-3.58 1.07a7.257 7.257 0 0 1-5.18-2.14c-1.38-1.38-2.14-3.26-2.14-5.18s.76-3.8 2.14-5.18c1.38-1.38 3.26-2.14 5.18-2.14.37 0 .73.03 1.09.09V12.01c-.36-.06-.72-.09-1.09-.09-1.92 0-3.48 1.56-3.48 3.48s1.56 3.48 3.48 3.48 3.48-1.56 3.48-3.48V.02z"
              ></path></svg
            >
          </a>
          <a
            href="#"
            class="w-10 h-10 rounded-full bg-white/10 flex items-center justify-center hover:bg-[#E4405F] transition-all group"
          >
            <span class="sr-only">Instagram</span>
            <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"
              ><path
                d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.981 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
              ></path></svg
            >
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="space-y-6">
        <h4
          class="font-bold text-lg underline decoration-[#3b82f6] decoration-2 underline-offset-8"
        >
          Enlaces Rápidos
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              href={base}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors flex items-center gap-2"
            >
              Inicio</a>
          </li>
          <li>
            <a
              href={`${base}portafolio`}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors flex items-center gap-2"
            >
              Portafolio</a>
          </li>
          <li>
            <a
              href={`${base}precios`}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors flex items-center gap-2"
            >
              Planes y Precios</a>
          </li>
          <li>
            <a
              href={`${base}contacto`}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors flex items-center gap-2"
            >
              Contacto Directo</a>
          </li>
        </ul>
      </div>

      <!-- Services -->
      <div class="space-y-6">
        <h4
          class="font-bold text-lg underline decoration-[#3b82f6] decoration-2 underline-offset-8"
        >
          Soluciones Digitales
        </h4>
        <ul class="space-y-3">
          <li>
            <a
              href={`${base}servicios/branding`}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors"
              >Diseño de Branding</a>
          </li>
          <li>
            <a
              href={`${base}servicios/landing-page`}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors"
              >Landing Page</a>
          </li>
          <li>
            <a
              href={`${base}servicios/web-corporativa`}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors"
              >Web Corporativa</a>
          </li>
          <li>
            <a
              href={`${base}servicios/ecommerce-pyme`}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors"
              >E-commerce Pyme</a>
          </li>
          <li>
            <a
              href={`${base}servicios/ecommerce-empresa`}
              class="text-sm text-[#93c5fd] hover:text-white transition-colors"
              >E-commerce Empresa</a>
          </li>
        </ul>
      </div>

      <!-- Newsletter -->
      <div class="space-y-6">
        <h4 class="font-bold text-lg">Suscríbete</h4>
        <p class="text-sm text-[#93c5fd]">
          Recibe las últimas actualizaciones y noticias directamente en tu
          correo.
        </p>
        <form
          id="newsletter-form"
          action="https://formspree.io/f/xykbjrkb"
          method="POST"
          class="space-y-3"
        >
          <input
            type="hidden"
            name="_subject"
            value="Nueva suscripción desde Digital Solutions"
          />
          <input
            type="email"
            name="email"
            required
            placeholder="Ingresa tu email"
            class="w-full px-4 py-3 rounded-lg bg-white/10 border border-white/20 text-white placeholder-[#93c5fd] focus:outline-none focus:border-white transition-colors text-sm"
          />
          <button
            type="submit"
            id="newsletter-submit"
            class="w-full py-3 bg-[#3b82f6] hover:bg-[#2563eb] text-white rounded-lg font-bold text-sm transition-colors shadow-md"
            >Suscribirse Ahora</button
          >
        </form>
        <div
          id="newsletter-success"
          class="hidden text-center py-2 bg-green-500/10 border border-green-500/20 rounded-lg"
        >
          <p class="text-green-400 text-xs font-bold">
            ¡Gracias por suscribirte!
          </p>
        </div>

        <script is:inline>
          const setupNewsletterForm = () => {
            const newsForm = document.getElementById("newsletter-form");
            const newsSuccess = document.getElementById("newsletter-success");
            if (newsForm) {
              newsForm.addEventListener("submit", async (e) => {
                e.preventDefault();
                const btn = document.getElementById("newsletter-submit");
                const originalText = btn.textContent;
                btn.textContent = "Enviando...";
                btn.disabled = true;
                try {
                  const res = await fetch(newsForm.action, {
                    method: "POST",
                    body: new FormData(newsForm),
                    headers: { Accept: "application/json" },
                  });
                  if (res.ok) {
                    newsForm.classList.add("hidden");
                    newsSuccess.classList.remove("hidden");
                  } else {
                    btn.textContent = "Error. Reintenta.";
                    btn.disabled = false;
                    setTimeout(() => {
                      btn.textContent = originalText;
                    }, 2000);
                  }
                } catch {
                  btn.textContent = "Error. Reintenta.";
                  btn.disabled = false;
                  setTimeout(() => {
                    btn.textContent = originalText;
                  }, 2000);
                }
              });
            }
          };

          // Run on initial load and every time the page changes
          document.addEventListener("astro:page-load", setupNewsletterForm);
        </script>
      </div>
    </div>

    <!-- Copyright -->
    <div
      class="text-center pt-8 border-t border-[#3b82f6]/30 text-xs text-[#93c5fd]"
    >
      <p>Copyright © 2026 Digital Solutions. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>
