---
const pathname = new URL(Astro.request.url).pathname;
const base = import.meta.env.BASE_URL;
const currentPath = pathname.replace(base, '').replace(/\/$/, '');
---

<nav id="navbar" class="fixed top-0 left-0 w-full z-[100] bg-transparent text-white pt-10 pb-6 flex justify-center transition-all duration-500">
  <div class="max-w-[1500px] w-full px-6 md:px-12 flex items-center justify-between">
    
    <!-- BRAND (Left) -->
    <a href={base} class="flex flex-col h-min leading-none tracking-widest uppercase group shrink-0 relative z-[110]">
      <span class="font-black text-2xl italic mb-1">Digital</span>
      <span class="font-bold text-[10px] opacity-60 border-t border-white/20 pt-1">Solutions</span>
    </a>

    <!-- DESKTOP LINKS (Hidden on Mobile) -->
    <div class="hidden lg:flex items-center justify-center gap-x-8 text-[14px] font-bold tracking-tight uppercase">
      <a href={base} id="link-home" class={`text-white hover:text-[#93c5fd] transition-colors duration-300 ${currentPath === "" ? 'text-[#93c5fd]' : ''}`}>Inicio</a>
      
      <!-- SERVICIOS DROPDOWN -->
      <div class="relative group h-full flex items-center">
        <button class={`flex items-center gap-1.5 transition-colors duration-300 py-2 text-[14px] font-bold uppercase tracking-tight ${currentPath.startsWith("servicios") ? 'text-[#93c5fd]' : 'text-white hover:text-[#93c5fd]'}`}>
          Servicios
          <svg class="w-3.5 h-3.5 text-white/70 group-hover:text-[#93c5fd] group-hover:rotate-180 transition-all duration-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M19 9l-7 7-7-7"></path></svg>
        </button>
        
        <!-- Dropdown Menu -->
        <div class="absolute top-[calc(100%-8px)] left-1/2 -translate-x-1/2 pt-4 opacity-0 translate-y-2 pointer-events-none group-hover:opacity-100 group-hover:translate-y-0 group-hover:pointer-events-auto transition-all duration-500 z-[100] min-w-[240px]">
           <div class="bg-[#0f172a] backdrop-blur-xl border border-white/10 rounded-[1.5rem] p-3 shadow-2xl overflow-hidden">
              <div class="absolute inset-0 bg-gradient-to-br from-blue-500/5 to-transparent"></div>
              <div class="relative z-10 space-y-1">
                  <a href={`${base}servicios/branding`} class="block px-4 py-3 rounded-xl hover:bg-white/10 transition-all group/item">
                    <span class="block text-[14px] font-bold text-white/90 group-hover/item:text-[#60a5fa] transition-colors">Diseños de Branding</span>
                    <span class="text-[11px] text-white/40 block leading-tight font-medium mt-0.5">Identidad corporativa y logotipos</span>
                 </a>
                 <a href={`${base}servicios/landing-page`} class="block px-4 py-3 rounded-xl hover:bg-white/10 transition-all group/item">
                    <span class="block text-[14px] font-bold text-white/90 group-hover/item:text-[#60a5fa] transition-colors">Landing Page</span>
                    <span class="text-[11px] text-white/40 block leading-tight font-medium mt-0.5">Conversión y captura de leads</span>
                 </a>
                 <a href={`${base}servicios/web-corporativa`} class="block px-4 py-3 rounded-xl hover:bg-white/10 transition-all group/item text-left">
                    <span class="block text-[14px] font-bold text-white/90 group-hover/item:text-[#60a5fa] transition-colors">Web Corporativa</span>
                    <span class="text-[11px] text-white/40 block leading-tight font-medium mt-0.5">Sitios multi-página escalables</span>
                 </a>
                 <a href={`${base}servicios/ecommerce-pyme`} class="block px-4 py-3 rounded-xl hover:bg-white/10 transition-all group/item text-left">
                    <span class="block text-[14px] font-bold text-white/90 group-hover/item:text-[#60a5fa] transition-colors">Tienda Online PYME</span>
                    <span class="text-[11px] text-white/40 block leading-tight font-medium mt-0.5">Venta fácil con Google Sheets</span>
                 </a>
                 <a href={`${base}servicios/ecommerce-empresa`} class="block px-4 py-3 rounded-xl hover:bg-white/10 transition-all group/item text-left">
                    <span class="block text-[14px] font-bold text-white/90 group-hover/item:text-[#60a5fa] transition-colors">E-commerce Empresa</span>
                    <span class="text-[11px] text-white/40 block leading-tight font-medium mt-0.5">Headless y alta transaccionabilidad</span>
                 </a>
              </div>
           </div>
        </div>
      </div>

      <a href={`${base}precios`} class={`transition-colors duration-300 ${currentPath === "precios" ? 'text-[#93c5fd]' : 'text-white hover:text-[#93c5fd]'}`}>Precios</a>
      <a href={`${base}portafolio`} class={`transition-colors duration-300 ${currentPath === "portafolio" ? 'text-[#93c5fd]' : 'text-white hover:text-[#93c5fd]'}`}>Portafolio</a>
      <a href={`${base}contacto`} class={`transition-colors duration-300 ${currentPath === "contacto" ? 'text-[#93c5fd]' : 'text-white hover:text-[#93c5fd]'}`}>Contacto</a>
    </div>

    <!-- SIDE PANEL (Right) -->
    <div class="flex items-center gap-6 relative z-[110]">
      <!-- Language Desktop (Hidden on mobile links panel) -->
      <div class="hidden lg:flex items-center bg-white/10 rounded-full p-1 border border-white/20 h-8 min-w-[70px] overflow-hidden">
        <div id="lang-pill" class="absolute top-1 left-1 h-[calc(100%-8px)] w-[calc(50%-4px)] bg-white rounded-full transition-all duration-300 shadow-md translate-x-0"></div>
        <button onclick="window.doGTranslate('es|es'); window.setLangPill('es')" class="relative z-10 px-3 h-full flex items-center justify-center text-[#2563EB] text-[10px] font-black cursor-pointer" id="btn-es">ES</button>
        <button onclick="window.doGTranslate('es|en'); window.setLangPill('en')" class="relative z-10 px-3 h-full flex items-center justify-center text-white text-[10px] font-black cursor-pointer" id="btn-en">EN</button>
      </div>

      <!-- Hamburger Button (Mobile Only) -->
      <button id="menuTrigger" class="lg:hidden flex flex-col justify-center items-center gap-1.5 w-10 h-10 bg-white/10 rounded-xl border border-white/20 transition-all active:scale-95 text-white">
        <span class="w-5 h-0.5 bg-white transition-all duration-300 rounded-full"></span>
        <span class="w-5 h-0.5 bg-white transition-all duration-300 rounded-full"></span>
      </button>
    </div>

  </div>

  <!-- MOBILE NAVIGATION DRAWER ALREADY MOVED OUT -->
</nav>

<!-- MOBILE NAVIGATION DRAWER -->
<div id="mobileMenu" class="fixed inset-0 bg-[#2563EB] z-[105] translate-x-full transition-transform duration-500 lg:hidden flex flex-col pt-32 px-8 pb-12 overflow-y-auto">
  <!-- Close Menu Trigger -->
  <button id="menuClose" class="absolute top-10 right-6 w-10 h-10 bg-white/10 rounded-xl border border-white/20 flex flex-col justify-center items-center gap-1.5 transition-all active:scale-95 text-white z-[120]">
    <span class="w-5 h-0.5 bg-white transition-all transform rotate-45 translate-y-[3.5px] rounded-full"></span>
    <span class="w-5 h-0.5 bg-white transition-all transform -rotate-45 -translate-y-[4.5px] rounded-full"></span>
  </button>

    <!-- Links -->
    <div class="flex flex-col space-y-8 text-2xl font-black tracking-tighter text-white uppercase">
      <a href={base} class="hover:text-blue-400 transition-colors">Inicio</a>
      
      <!-- Mobile Services (Accordion style) -->
      <div class="space-y-4">
        <button id="mobileServicesToggle" class="flex items-center gap-4 hover:text-blue-400 transition-colors">
          Servicios <svg class="w-6 h-6 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path d="M19 9l-7 7-7-7"></path></svg>
        </button>
        <div id="mobileServicesList" class="hidden flex flex-col translate-y-[-10px] opacity-0 transition-all duration-300">
          <!-- Dark card container -->
          <div class="mt-3 bg-[#0f172a] rounded-2xl overflow-hidden border border-white/10">
            <a href={`${base}servicios/branding`} class="flex items-center gap-4 p-4 hover:bg-white/5 transition-colors border-b border-white/5">
              <div class="w-9 h-9 rounded-xl bg-blue-500/20 text-blue-400 flex items-center justify-center shrink-0">
                 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-bold text-white normal-case leading-tight">Diseños de Branding</span>
                <span class="block text-[10px] text-white/40 normal-case font-medium mt-0.5">Identidad corporativa y logotipos</span>
              </div>
            </a>
            <a href={`${base}servicios/landing-page`} class="flex items-center gap-4 p-4 hover:bg-white/5 transition-colors border-b border-white/5">
              <div class="w-9 h-9 rounded-xl bg-blue-500/20 text-blue-400 flex items-center justify-center shrink-0">
                 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-bold text-white normal-case leading-tight">Landing Page</span>
                <span class="block text-[10px] text-white/40 normal-case font-medium mt-0.5">Conversión y captura de leads</span>
              </div>
            </a>
            <a href={`${base}servicios/web-corporativa`} class="flex items-center gap-4 p-4 hover:bg-white/5 transition-colors border-b border-white/5">
              <div class="w-9 h-9 rounded-xl bg-blue-500/20 text-blue-400 flex items-center justify-center shrink-0">
                 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-bold text-white normal-case leading-tight">Web Corporativa</span>
                <span class="block text-[10px] text-white/40 normal-case font-medium mt-0.5">Sitios multi-página escalables</span>
              </div>
            </a>
            <a href={`${base}servicios/ecommerce-pyme`} class="flex items-center gap-4 p-4 hover:bg-white/5 transition-colors border-b border-white/5">
              <div class="w-9 h-9 rounded-xl bg-blue-500/20 text-blue-400 flex items-center justify-center shrink-0">
                 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-bold text-white normal-case leading-tight">Tienda Online PYME</span>
                <span class="block text-[10px] text-white/40 normal-case font-medium mt-0.5">Venta fácil con Google Sheets</span>
              </div>
            </a>
            <a href={`${base}servicios/ecommerce-empresa`} class="flex items-center gap-4 p-4 hover:bg-white/5 transition-colors">
              <div class="w-9 h-9 rounded-xl bg-blue-500/20 text-blue-400 flex items-center justify-center shrink-0">
                 <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"></path></svg>
              </div>
              <div>
                <span class="block text-sm font-bold text-white normal-case leading-tight">E-commerce Empresa</span>
                <span class="block text-[10px] text-white/40 normal-case font-medium mt-0.5">Headless y alta transaccionabilidad</span>
              </div>
            </a>
          </div>
        </div>
      </div>

      <a href={`${base}precios`} class="hover:text-blue-400 transition-colors">Precios</a>
      <a href={`${base}portafolio`} class="hover:text-blue-400 transition-colors">Portafolio</a>
      <a href={`${base}contacto`} class="hover:text-blue-400 transition-colors">Contacto</a>
    </div>

    <!-- Mobile Footer Info -->
    <div class="mt-auto pt-12 border-t border-white/10 space-y-6">


      <!-- Mobile Language Switch -->
      <div class="flex gap-4">
        <button onclick="window.doGTranslate('es|es'); window.setLangPill('es')" class="text-xs font-black text-white/40 hover:text-white transition-colors">Español</button>
        <button onclick="window.doGTranslate('es|en'); window.setLangPill('en')" class="text-xs font-black text-white/40 hover:text-white transition-colors">English</button>
      </div>
    </div>
  </div>


<script>
  // ---- NAVBAR INIT (runs on every Astro page navigation) ----
  function initNavbar() {
    const trigger   = document.getElementById('menuTrigger') as HTMLButtonElement | null;
    const closeBtn  = document.getElementById('menuClose')   as HTMLButtonElement | null;
    const menu      = document.getElementById('mobileMenu')  as HTMLElement | null;
    const servicesToggle = document.getElementById('mobileServicesToggle') as HTMLButtonElement | null;
    const servicesList   = document.getElementById('mobileServicesList')   as HTMLElement | null;
    let menuOpen = false;

    // Toggle mobile drawer
    function toggleMenu(e?: Event) {
      e?.preventDefault();
      menuOpen = !menuOpen;
      if (menuOpen) {
        menu?.classList.remove('translate-x-full');
        menu?.classList.add('translate-x-0');
        if (trigger) {
          (trigger.children[0] as HTMLElement).style.transform = 'rotate(45deg) translateY(6px)';
          (trigger.children[1] as HTMLElement).style.transform = 'rotate(-45deg) translateY(-6px)';
        }
        document.body.style.overflow = 'hidden';
      } else {
        menu?.classList.add('translate-x-full');
        menu?.classList.remove('translate-x-0');
        if (trigger) {
          (trigger.children[0] as HTMLElement).style.transform = 'none';
          (trigger.children[1] as HTMLElement).style.transform = 'none';
        }
        document.body.style.overflow = '';
      }
    }

    if (trigger)  trigger.onclick  = toggleMenu;
    if (closeBtn) closeBtn.onclick = toggleMenu;

    // Mobile services accordion
    if (servicesToggle && servicesList) {
      servicesToggle.onclick = () => {
        const isHidden = servicesList.classList.contains('hidden');
        if (isHidden) {
          servicesList.classList.remove('hidden');
          setTimeout(() => {
            servicesList.style.opacity   = '1';
            servicesList.style.transform = 'translateY(0)';
          }, 10);
        } else {
          servicesList.style.opacity   = '0';
          servicesList.style.transform = 'translateY(-10px)';
          setTimeout(() => servicesList.classList.add('hidden'), 300);
        }
        (servicesToggle.children[0] as HTMLElement)?.classList.toggle('rotate-180');
      };
    }

    // Scroll → solid background
    function handleScroll() {
      const nav = document.getElementById('navbar');
      if (!nav) return;
      if (window.scrollY > 50) {
        nav.style.background = '#2563EB';
        nav.style.boxShadow  = '0 4px 30px rgba(0,0,0,0.2)';
        nav.style.paddingTop = '1.25rem';
      } else {
        nav.style.background = 'transparent';
        nav.style.boxShadow  = 'none';
        nav.style.paddingTop = '2.5rem';
      }
    }

    window.addEventListener('scroll', handleScroll, { passive: true });
    handleScroll();
  }

  // ---- LANGUAGE PILL ----
  function setLangPill(lang: string) {
    const pill  = document.getElementById('lang-pill');
    const btnEs = document.getElementById('btn-es');
    const btnEn = document.getElementById('btn-en');
    if (!pill) return;
    if (lang === 'en') {
      pill.style.transform = 'translateX(calc(100% + 4px))';
      btnEn?.classList.replace('text-white',    'text-[#2563EB]');
      btnEs?.classList.replace('text-[#2563EB]', 'text-white');
    } else {
      pill.style.transform = 'translateX(0)';
      btnEs?.classList.replace('text-white',    'text-[#2563EB]');
      btnEn?.classList.replace('text-[#2563EB]', 'text-white');
    }
  }
  (window as any).setLangPill = setLangPill;

  function initLang() {
    const cookie = document.cookie.split('; ').find(r => r.startsWith('googtrans='));
    setLangPill(cookie?.includes('/en') ? 'en' : 'es');
  }

  // Run on every page (Astro View Transitions compatible)
  document.addEventListener('astro:page-load', () => {
    initNavbar();
    initLang();
  });
</script>

<style>
  #navbar {
    will-change: transform, padding, background;
  }
</style>